{% set name = "multipsi" %}
{% set version = "@_version_@" %}

package:
  name: {{ name|lower }}
  version: {{ version }}

source:
  path: ../../multipsi

build:
  number: @_build_@
  script_env:
    - OMPI_MCA_plm_rsh_agent=  # [mpi == 'openmpi' and linux]

requirements:
  build:
    - cmake >=3.18
    - {{ compiler('cxx') }}
    - llvm-openmp
    - vs2022_win-64  # [win]
    - ninja
  host:
    - pybind11
    - python
    - pybind11-abi =4
    - eigen
    - {{ mpi }}
    - mpi4py
    - numpy
  run:
    - veloxchem >=1.0rc4
    - scipy
    - python
    - msmpi  # [win]
    - {{ pin_compatible('mpi4py') }}
    - numpy

test:
  requires:
    - pytest
    - libblas
    - mkl          # [win]
    - pip
    - scipy
  source_files:
    - tests/
  imports:
    - multipsi
  commands:
    # Inspect linkage
    - ldd -v $SP_DIR/multipsi/multipsilib*.so  # [linux]
    - otool -L $SP_DIR/multipsi/multipsilib*.so  # [osx]
    # run integration tests
    - export OMPI_ALLOW_RUN_AS_ROOT=1  # [mpi == 'openmpi']
    - export OMPI_ALLOW_RUN_AS_ROOT_CONFIRM=1  # [mpi == 'openmpi']
    # run integration tests on unix-like systems
    - export OMP_NUM_THREADS=$CPU_COUNT  # [unix]
    - mpiexec -n 1 $PYTHON -m pytest --capture=no --log-cli-level=INFO  # [unix]
    - export MPI_NUM_PROCS=2  # [unix]
    - export OMP_NUM_THREADS=$(($CPU_COUNT/$MPI_NUM_PROCS))  # [unix]
    - mpiexec -n $MPI_NUM_PROCS $PYTHON -m pytest --capture=no --log-cli-level=INFO -m "parallel"  # [unix]
    # run integration tests on windows
    - set OMP_NUM_THREADS=%CPU_COUNT%  # [win]
    - mpiexec -n 1 %PYTHON% -m pytest --capture=no --log-cli-level=INFO  # [win]
    - set MPI_NUM_PROCS=2  # [win]
    - set /A OMP_NUM_THREADS="%CPU_COUNT%/%MPI_NUM_PROCS%"  # [win]
    - mpiexec -n %MPI_NUM_PROCS% %PYTHON% -m pytest --capture=no --log-cli-level=INFO -m "parallel" -k "not test_mcscfdriver"  # [win]

about:
  home: https://multipsi.org
  dev_url: https://gitlab.com/MGDelcey/multipsi
  doc_url: https://mgdelcey.github.io/mtpman/
  doc_source_url: https://github.com/MGDelcey/mtpman/blob/master/docs/intro.md
  license: LGPL-3.0-or-later
  license_url: https://opensource.org/licenses/LGPL-3.0
  license_file:
    - COPYING
    - COPYING.LESSER
  license_family: LGPL
  summary: A multireference quantum chemistry extension of VeloxChem

extra:
  recipe-maintainers:
    - delcey
    - robertodr
